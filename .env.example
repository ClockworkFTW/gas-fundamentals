# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Power Automate "When an HTTP request is received" trigger URL
POWER_AUTOMATE_URL=https://prod-00.westus.logic.azure.com:443/workflows/...

# Shared-secret header value the Power Automate flow verifies (guards the trigger URL)
POWER_AUTOMATE_SHARED_SECRET=replace-with-a-long-random-string

# Optional: HTTP header name carrying the shared secret (default: X-Shared-Secret)
POWER_AUTOMATE_SECRET_HEADER=X-Shared-Secret

# EIA Open Data API v2 key — https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key-here

# Ruby (Tallgrass) sits behind an Incapsula WAF — a plain requests GET is challenged.
# Paste the full 'Cookie:' header from a browser session that has loaded the Ruby OA
# page (devtools → Network → request → Cookie). The data pull is requests-based; this
# clearance cookie just gets past the WAF. It expires — refresh when ruby.py reports a
# challenge (RubyChallengeError). No headless browser is used for ingestion.
RUBY_COOKIE=ASP.NET_SessionId=...; visid_incap_2123500=...; incap_ses_187_2123500=...
